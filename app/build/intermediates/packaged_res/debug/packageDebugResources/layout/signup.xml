<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_green"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="32dp"
        android:paddingTop="64dp"
        android:paddingBottom="48dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up"
            android:textColor="@color/accent_pink"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Email -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/rounded_input_bg"
            android:hint="email"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="18dp"
            android:paddingVertical="0dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Password -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_input_bg"
            android:hint="password"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:inputType="textPassword"
            android:paddingHorizontal="18dp"
            android:paddingVertical="0dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/etEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Your number -->
        <EditText
            android:id="@+id/etYourNumber"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_input_bg"
            android:hint="your number"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:inputType="phone"
            android:paddingHorizontal="18dp"
            android:paddingVertical="0dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/etPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Monitored person's number -->
        <EditText
            android:id="@+id/etMonitoredNumber"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_input_bg"
            android:hint="number of the monitored person"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:inputType="phone"
            android:paddingHorizontal="18dp"
            android:paddingVertical="0dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/etYourNumber"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Monitored person's address -->
        <EditText
            android:id="@+id/etMonitoredAddress"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_input_bg"
            android:hint="address of the monitored person"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:inputType="textPostalAddress"
            android:paddingHorizontal="18dp"
            android:paddingVertical="0dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/etMonitoredNumber"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Finish button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinish"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Finish"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:backgroundTint="@color/button_teal"
            app:cornerRadius="14dp"
            app:layout_constraintTop_toBottomOf="@id/etMonitoredAddress"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Already signed up -->
        <TextView
            android:id="@+id/tvGoToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Already signed up? Log in"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/btnFinish"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>