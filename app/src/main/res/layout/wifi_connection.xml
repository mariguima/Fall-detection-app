<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="We are almost done!"
        android:textColor="@color/accent_pink"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/card_cream"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvWifiTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Now, just connect it to wi-fi"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvWifiSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Your device needs wi-fi to send alerts. Use the same wi-fi your home is on."
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvWifiTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <EditText
                android:id="@+id/etNetworkName"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:hint="Network name"
                android:textColorHint="@color/hint_gray"
                android:textColor="@color/text_dark"
                android:background="@drawable/rounded_input_bg"
                android:paddingHorizontal="16dp"
                android:inputType="text"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvWifiSubtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:hint="Password"
                android:textColorHint="@color/hint_gray"
                android:textColor="@color/text_dark"
                android:background="@drawable/rounded_input_bg"
                android:paddingHorizontal="16dp"
                android:inputType="textPassword"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/etNetworkName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConnect"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:text="Connect"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/button_teal"
                app:cornerRadius="14dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"
                app:layout_constraintTop_toBottomOf="@id/etPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>