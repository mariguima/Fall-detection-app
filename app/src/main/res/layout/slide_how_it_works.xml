<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:tag="slide_1"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="How it works"
        android:textColor="#C0436A"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Feature 1 -->
    <TextView
        android:id="@+id/tvFeature1Title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Detects falls automatically"
        android:textColor="#2D2D2D"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvFeature1Desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="The camera uses AI to spot a fall in real time — no button to press."
        android:textColor="#5A5A5A"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvFeature1Title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Feature 2 -->
    <TextView
        android:id="@+id/tvFeature2Title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Instant alerts to your phone"
        android:textColor="#2D2D2D"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvFeature1Desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvFeature2Desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="You get a notification with a photo so you can see exactly what happened."
        android:textColor="#5A5A5A"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvFeature2Title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Feature 3 -->
    <TextView
        android:id="@+id/tvFeature3Title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Private and secure"
        android:textColor="#2D2D2D"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvFeature2Desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvFeature3Desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Images are only sent when a fall is detected. Nothing is recorded or stored otherwise."
        android:textColor="#5A5A5A"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvFeature3Title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>